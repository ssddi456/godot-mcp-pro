{
  "name": "godot-mcp-pro-server",
  "version": "1.0.0",
  "description": "Godot MCP Pro daemon and stdio/CLI clients for the Godot editor plugin.",
  "license": "SEE LICENSE IN ../LICENSE",
  "type": "module",
  "main": "build/index.js",
  "bin": {
    "godot-mcp-pro-server": "build/server.js",
    "godot-mcp-pro": "build/index.js",
    "godot-mcp-pro-cli": "build/cli.js"
  },
  "files": [
    "build/",
    "README.md"
  ],
  "scripts": {
    "generate": "node scripts/generate-tools.mjs",
    "prebuild": "npm run generate",
    "build": "tsc -p tsconfig.json && node scripts/postbuild.mjs",
    "start": "node build/server.js",
    "mcp": "node build/index.js",
    "cli": "node build/cli.js",
    "test": "node --test build/test/*.test.js || true"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.26.0",
    "commander": "^14.0.1",
    "ws": "^8.18.3",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/ws": "^8.5.13",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=18"
  }
}
